# ── Required ──────────────────────────────────────────────────────────
# Your AgentGauntlet API key. Get one at https://agentgauntlet.ai/keys.html
# (free tier: 100 runs/day; event tier active during a hackathon: 1000/day)
AG_KEY=agg_yourkeyhere

# ── Optional ──────────────────────────────────────────────────────────
# LLM provider. One of: anthropic | openai | google | none
# Default: none. Pick whichever you have a key for. Four of seven
# scenarios (bank-login, payment-checkout, auction, crypto-exchange) can
# be solved without an LLM at all — they're pure DOM scraping.
LLM_PROVIDER=none

# API key for the chosen LLM provider. Required if LLM_PROVIDER != 'none'.
LLM_API_KEY=

# Optional model override. Defaults per provider:
#   anthropic → claude-sonnet-4-6
#   openai    → gpt-4o
#   google    → gemini-2.0-flash
LLM_MODEL=

# AgentGauntlet base URL. Override only if you're running a self-hosted
# instance or pointing at a staging deploy.
AG_BASE_URL=https://agentgauntlet.ai

# Set to 'true' to see the browser window during runs (useful for debugging).
# Default: false (headless).
HEADFUL=false

# Optional: event slug if you've joined a hackathon event. Currently
# informational only — your AG_KEY is what's checked against event
# membership server-side.
AG_EVENT=
